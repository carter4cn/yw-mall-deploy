# yw-mall-deploy environment variables
# Override these for different environments.

# Infra network name (must match the env project's compose network)
INFRA_NETWORK=infra

# JWT secret — must match all RPC services
JWT_SECRET=mall-secret-key-change-in-production

# Admin token for mall-api
ADMIN_TOKEN=mall-admin-token-change-in-production

# MinIO credentials (must match env/compose.yml)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123
