# yw-mall-deploy environment variables
# Override these for different environments.

# Docker network created by env/compose.yml with --project-name env.
# Format: {project_name}_{network_name_in_compose}
INFRA_NETWORK=env_infra

# JWT secret — must match all RPC service configs
JWT_SECRET=mall-secret-key-change-in-production

# Admin token for mall-api
ADMIN_TOKEN=mall-admin-token-change-in-production

# MinIO credentials (must match env/compose.yml)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin123

# etcd endpoints for configcenter (comma-separated).
# Services read config from etcd on startup when this is set.
# Matches the etcd cluster defined in env/compose.yml.
ETCD_HOSTS=etcd1:2379,etcd2:2379,etcd3:2379
